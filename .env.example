# Vault connection
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root
VAULT_NAMESPACE=

# AppRole auth (alternative to token)
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# PagerDuty
PAGERDUTY_ROUTING_KEY=your-routing-key-here
